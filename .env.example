# Optional. Enables the AI cleanup/rebuild pass.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
AI_CLEANUP=true
AI_UPLOAD_ANALYSIS=true

# Optional. Enables Firebase sign up/sign in.
# Backend verification. Prefer FIREBASE_SERVICE_ACCOUNT_JSON on Railway.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"killer-work","private_key_id":"...","private_key":"...","client_email":"..."}
# Local alternative for the downloaded Firebase admin JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/Users/greenethirteen/Downloads/killer-work-firebase-adminsdk-fbsvc-944f372ec4.json

# Frontend Firebase Web App config from Firebase Console > Project settings > Your apps.
FIREBASE_PROJECT_ID=killer-work
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
FIREBASE_AUTH_DOMAIN=killer-work.firebaseapp.com
FIREBASE_WEB_APP_ID=your_firebase_web_app_id_here
FIREBASE_MEASUREMENT_ID=

# Required for paid publishing and ZIP downloads.
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_MONTHLY_PRICE_ID=price_1Tb1w7CE6bX7hMAXXOoILehR
# Optional. Used for Stripe Checkout return URLs in production.
# PUBLIC_APP_URL=https://killa.work

# Optional if Playwright cannot find your local Chrome.
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

PORT=8787

# Optional. Set this to your persistent Railway volume mount so generated previews survive deploys/restarts.
# If omitted, Railway's automatic RAILWAY_VOLUME_MOUNT_PATH is used when a volume is attached.
# GENERATED_DIR=/data/generated
